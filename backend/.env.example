# Database (PostgreSQL on Render, or leave empty to use local SQLite)
DATABASE_URL=postgresql://user:password@host/dbname

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-replace-with-random-string

# Admin credentials
ADMIN_EMAIL=admin@barbershop.kz
ADMIN_PASSWORD=changeme123

# Telegram bot
TELEGRAM_BOT_TOKEN=123456789:AABBCCddEEFFggHH...
TELEGRAM_ADMIN_CHAT_ID=123456789
